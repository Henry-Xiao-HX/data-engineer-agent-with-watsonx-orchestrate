# =============================================================================
# IBM watsonx Data Intelligence MCP Server - Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication (choose ONE method)
# -----------------------------------------------------------------------------

# Option A: IBM Cloud API Key (SaaS)
DI_APIKEY=your-ibm-cloud-api-key-here

# Option B: Bearer token (alternative to API key)
# DI_AUTH_TOKEN=your-bearer-token-here

# Option C: CPD username + API key (CPD only)
# DI_APIKEY=your-cpd-api-key-here
# DI_USERNAME=your-cpd-username-here

# -----------------------------------------------------------------------------
# Service URL
# -----------------------------------------------------------------------------

# IBM Cloud SaaS (default)
DI_SERVICE_URL=https://api.dataplatform.cloud.ibm.com

# IBM Cloud Pak for Data (CPD) - replace with your cluster URL
# DI_SERVICE_URL=https://your-cpd-cluster.example.com

# -----------------------------------------------------------------------------
# Environment Mode
# -----------------------------------------------------------------------------

# SaaS (default) or CPD
DI_ENV_MODE=SaaS

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Required for stdio mode - path to write server logs
LOG_FILE_PATH=/tmp/di-mcp-server.log

# -----------------------------------------------------------------------------
# Optional Settings
# -----------------------------------------------------------------------------

# HTTP request timeout in seconds (default: 60)
REQUEST_TIMEOUT_S=60

# Context for UI URLs: df or cpdaas (SaaS); df or cpd (CPD)
DI_CONTEXT=df

# =============================================================================
# watsonx Orchestrate Developer Edition (local server)
# =============================================================================

# Orchestrate environment URL (local Developer Edition)
ORCHESTRATE_URL=http://localhost:4321

# Orchestrate API key / credentials
ORCHESTRATE_API_KEY=your-orchestrate-api-key-here